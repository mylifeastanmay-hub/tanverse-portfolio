# Server Configuration
PORT=5000
ADMIN_PASSWORD=admin123
JWT_SECRET=super_secret_cyber_jwt_key_1337

# Database Configuration
# Set DB_TYPE to 'mssql' to use SQL Server, or 'sqlite' to use the local file database fallback
DB_TYPE=mssql

# SQL Server Configuration (required if DB_TYPE=mssql)
DB_USER=your_sql_server_user
DB_PASSWORD=your_sql_server_password
DB_SERVER=localhost
DB_DATABASE=portfolio_db
DB_TRUST_SERVER_CERTIFICATE=true

# SQLite Configuration (used if DB_TYPE=sqlite or fallback)
SQLITE_PATH=./data/portfolio.db
