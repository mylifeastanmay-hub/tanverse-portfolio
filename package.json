{
  "name": "jack-3d-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite --config vite.config.mjs --configLoader runner --port 5174",
    "dev:server": "npm run dev --prefix server",
    "dev:admin": "npm run dev --prefix admin",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:admin\"",
    "build": "tsc -p tsconfig.app.json && vite build --config vite.config.mjs --configLoader runner",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
